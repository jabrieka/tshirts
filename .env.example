# Database
# Local (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Neon Postgres) — set prisma datasource provider to "postgresql" in prisma/schema.prisma:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Vercel Blob (optional — required for uploads in production on Vercel since the
# Vercel runtime has a read-only filesystem). Create a Blob store in your project
# and Vercel will inject this token automatically.
# BLOB_READ_WRITE_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BRAND_NAME="Cosette Productions"

# Admin auth (iron-session)
SESSION_PASSWORD="change_me_to_a_32_plus_char_random_secret_xxxxxx"
ADMIN_EMAIL="admin@cosetteproductions.com"
ADMIN_PASSWORD="changeMe!"

# Stripe (optional — orders can fall back to manual invoice mode if not set)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email notifications (Resend) — new custom requests & orders are emailed here.
# Without RESEND_API_KEY, sending is skipped silently (forms still save to DB).
RESEND_API_KEY=""
CONTACT_EMAIL="cosetteproductions@gmail.com"
# Verified sender. Default onboarding@resend.dev only delivers to your own
# Resend account email; use a verified domain sender for real delivery.
EMAIL_FROM="Cosette Productions <onboarding@resend.dev>"

# Upload directory (local filesystem)
UPLOAD_DIR="public/uploads"
